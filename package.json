{
  "name": "jscodeshiftor",
  "version": "0.0.0-dev",
  "license": "MIT",
  "main": "index.js",
  "keywords": [
    "jscodeshift",
    "codemod"
  ],
  "bin": "./bin/cli.js",
  "scripts": {
    "test": "npm run eslint && npm run tscheck && npm run test:r",
    "test:r": "vitest run",
    "test:w": "vitest",
    "test:cov": "vitest run --coverage",
    "lint": "npm run eslint && npm run tscheck",
    "eslint": "node node_modules/eslint/bin/eslint \"src/**/*.{ts,tsx}\"",
    "eslint:fix": "npm run eslint -- --fix",
    "eslint:w": "onchange * -v -k -i -- npm run eslint",
    "tscheck": "tsc --noEmit",
    "tscheck:w": "npm run tscheck -- --watch",
    "format:src": "prettier src --write"
  },
  "dependencies": {
    "jscodeshift": "^17.3.0",
    "namify": "^0.1.3",
    "strip-indent": "^4.1.1"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.5",
    "@types/jscodeshift": "^17.3.0",
    "@types/node": "^25.9.1",
    "@vitest/coverage-v8": "^4.1.7",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-only-warn": "^1.2.1",
    "eslint-plugin-perfectionist": "^5.9.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-unicorn": "^64.0.0",
    "globals": "^17.6.0",
    "jscodeshift-helper": "^1.1.0",
    "prettier": "^3.8.3",
    "recast": "^0.23.11",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tslib": "^2.8.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.4",
    "vitest": "^4.1.7"
  }
}
